# Postgres
POSTGRES_DB=your_db_name
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_strong_db_password
POSTGRES_HOST_PORT=5433

# Backend database DSN
DATABASE_URL=postgresql+asyncpg://your_db_user:your_strong_db_password@db:5432/your_db_name

# FastAPI
APP_NAME=PopScope Backend
APP_ENV=dev
APP_DEBUG=true
API_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:5173"]

# Reports / LLM
REPORT_USE_LLM=false/true
LLM_PROVIDER=stub/gigachat

GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_TEMPERATURE=0.2
GIGACHAT_MAX_TOKENS=1200
GIGACHAT_TIMEOUT_SECONDS=30
GIGACHAT_SSL_VERIFY=true
GIGACHAT_CA_BUNDLE_PATH=

# Frontend
VITE_API_URL=http://localhost:8000
