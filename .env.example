# Postgres
POSTGRES_DB=your_db_name
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_strong_db_password
POSTGRES_HOST_PORT=5433

# Backend database DSN
DATABASE_URL=postgresql+asyncpg://your_db_user:your_strong_db_password@db:5432/your_db_name

# FastAPI
APP_NAME=PopScope Backend
APP_ENV=dev
APP_DEBUG=true
API_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:5173"]

# Reports / LLM
REPORT_USE_LLM=false
LLM_PROVIDER=stub
YANDEX_GPT_API_KEY=
YANDEX_GPT_FOLDER_ID=
YANDEX_GPT_MODEL_URI_TEMPLATE=gpt://{folder_id}/yandexgpt/latest
YANDEX_GPT_BASE_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/completion
YANDEX_GPT_TEMPERATURE=0.2
YANDEX_GPT_MAX_TOKENS=1200
YANDEX_GPT_TIMEOUT_SECONDS=30

# Frontend
VITE_API_URL=http://localhost:8000
